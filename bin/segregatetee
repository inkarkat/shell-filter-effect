#!/bin/bash
shopt -qs extglob

printShortUsage()
{
    # Note: short followed by long option; if the user knows the short one, she can
    # skim the long one.
    printf 'Usage: %q %s\n' "$(basename "$1")" '([--to DEFAULT-FILE [--to ...]] -m|--match PATTERN|-v|--no-match PATTERN [-a|--append] [--] [FILE ...]) ... [-f|--fallback [-a|--append] FALLBACK-FILE] [-?|-h|--help]'
}
printUsage()
{
    # This is the short help when launched with no or incorrect arguments.
    # It is printed to stderr to avoid accidental processing.
    printShortUsage "$1" >&2
    printf >&2 '\nTry %q --help for more information.\n' "$(basename "$1")"
}
printLongUsage()
{
    # This is the long "man page" when launched with the help argument.
    # It is printed to stdout to allow paging with 'more'.
    cat <<HELPDESCRIPTION
Read from standard input and write all (non-)matching lines to FILE(s). The
first consumer wins; i.e. each line is only written to a single (set of)
FILE(s). Any left-over lines are written to standard output.
HELPDESCRIPTION
    echo
    printShortUsage "$1"
    cat <<HELPTEXT
    --to DEFAULT-FILE	    Write to DEFAULT-FILE if no FILE(s) are given to a
			    following --[no-]match parameter (instead of falling
			    back to standard output). This allows to specify a
			    FILE once for multiple PATTERNs without repeating it
			    (which is important when using a single process
			    substitution). Another --to DEFAULT-FILE adds to the
			    list as long as no --[no-]match parameter has been
			    encountered yet, and resets the list of default
			    files once a --[no-]match parameter is encountered.
    --match|-m PATTERN	    Only consider lines that match PATTERN when writing
			    to the following FILE(s). If no FILE(s) are given,
			    write to standard output / FALLBACK-FILE.
    --no-match|-v PATTERN   Only consider lines that do not match PATTERN when
			    writing to the following FILE(s). If no FILE(s) are
			    given, write to standard output.
    --fallback|-f FALLBACK-FILE
			    Write to FALLBACK-FILE instead of standard output if
			    no PATTERN matches.
    --append|-a		    Append to the following FILE(s) instead of
			    truncating them. Only applies to the following (set
			    of) FILE(s) (or DEFAULT-FILE(s) or FALLBACK-FILE).
    PATTERN is a POSIX-style unanchored extended regular expression.

SEE ALSO:
- filtertee sends lines (or specificially non-whitespace lines) to FILE(s) based
  on patterns but also prints everything to stdout.
HELPTEXT
}

typeset -a filespecs=()
addFiles()
{
    local varname="${1:?}"; shift
    local file; for file
    do
	local i; for ((i = 0; i < ${#filespecs[@]}; i++))
	do
	    if [ "$file" = "${filespecs[$i]}" ]; then
		eval "${varname}+=\"\$i \""
		return
	    fi
	done
	eval "${varname}+=\"\${#filespecs[@]} \""
	filespecs+=("$file")
    done
}
handleDefaultFiles()
{
    [ -n "$lastPattern" ] && [ -z "${matchFileIndices["$lastPattern"]}" ] || return
    addFiles 'matchFileIndices["$lastPattern"]' "${defaultFiles[@]}"
}

isDefaultFilesUsed=
lastPattern=
typeset -a matchPatterns=()
typeset -A matchIsExclude=()
typeset -A matchIsAppend=()
typeset -A matchFileIndices=()
fallbackIsAppend=
fallbackFileIndices=
typeset -a defaultFiles=()
while [ $# -ne 0 ]
do
    case "$1" in
	--help|-h|-\?)	shift; printLongUsage "$0"; exit 0;;

	--match=*)	handleDefaultFiles; lastPattern="${1#--match=}"; shift; matchPatterns+=("$lastPattern"); matchIsExclude["$lastPattern"]=; isDefaultFilesUsed=t;;
	--match|-m)	shift; handleDefaultFiles; lastPattern="${1:?}"; shift; matchPatterns+=("$lastPattern"); matchIsExclude["$lastPattern"]=; isDefaultFilesUsed=t;;
	--no-match=*)	handleDefaultFiles; lastPattern="${1#--no-match=}"; shift; matchPatterns+=("$lastPattern"); matchIsExclude["$lastPattern"]=t; isDefaultFilesUsed=t;;
	--no-match|-v)	shift; handleDefaultFiles; lastPattern="${1:?}"; shift; matchPatterns+=("$lastPattern"); matchIsExclude["$lastPattern"]=t; isDefaultFilesUsed=t;;

	--fallback|-f)	shift
			if [[ "$1" = @(--append|-a) ]]; then
			    shift
			    fallbackIsAppend=t
			fi
			addFiles fallbackFileIndices "${1:?}"
			shift
			lastPattern=''
			;;
	--to)		shift
			handleDefaultFiles
			if [ "$isDefaultFilesUsed" ]; then
			    isDefaultFilesUsed=
			    defaultFiles=("${1:?}")
			else
			    defaultFiles+=("${1:?}")
			fi
			shift
			lastPattern=''
			;;
	--append|-a)	shift
			if [ -z "$lastPattern" ]; then
			    echo 'ERROR: --append must follow a --match or --no-match parameter.'
			    echo
			    printUsage "$0"
			    exit 2
			elif [ -n "${matchFileIndices["$lastPattern"]}" ]; then
			    echo 'ERROR: --append must immediately follow a --match or --no-match parameter.'
			    echo
			    printUsage "$0"
			    exit 2
			fi >&2
			matchIsAppend["$lastPattern"]=t
			;;
	-|-[^-]*|--?*)	{ echo "ERROR: Unknown option \"$1\"!"; echo; printUsage "$0"; } >&2; exit 2;;
	--)		shift;&
	*)		if [ -z "$lastPattern" ]; then
			    printf 'ERROR: FILE(s) must follow a --match or --no-match parameter: %s\n' "$1"
			    echo
			    printUsage "$0"
			    exit 2
			fi >&2
			addFiles 'matchFileIndices["$lastPattern"]' "${1:?}"
			shift
			;;
    esac
done
handleDefaultFiles
if [ ${#matchPatterns[@]} -eq 0 ]; then
    echo 'ERROR: No --match or --no-match passed.'
    echo
    printUsage "$0"
    exit 2
fi >&2

write()
{
    local contents="${1?}"; shift
    local fileIndices="${1?}"; shift
    local isAppend="${1?}"; shift

    if [ -z "$fileIndices" ]; then
	printf %s "$contents"
	return
    fi

    local i; for i in $fileIndices
    do
	local file="${filespecs[$i]}"
	[ -n "$file" ] || continue
	eval 'printf %s "$contents"' ">${isAppend:+>}" '"$file"' || {
	    status=1
	    filespecs[$i]=''	# Remove a problematic file from the roster; this is different from tee's behavior which keeps open a file handle and therefore isn't affected by chmod or removal after the fact.
	}
    done
}

status=0
# Try to truncate / open for writing all passed FILEs at the beginning; this is
# how tee works, too. We can sift out problematic files already here.
for match in "${matchPatterns[@]}"
do
    write '' "${matchFileIndices["$match"]}" "${matchIsAppend["$match"]}"
done
[ -z "$fallbackFileIndices" ] || write '' "$fallbackFileIndices" "$fallbackIsAppend"

EOL=$'\n'
while IFS=$'\n' read -r line || { EOL=; [ -n "$line" ]; }
do
    hasMatch=
    for match in "${matchPatterns[@]}"
    do
	isExclude="${matchIsExclude["$match"]}"
	isMatch=; [[ "$line" =~ $match ]] && isMatch=t
	if { [ "$isExclude" ] && [ ! "$isMatch" ]; } \
	    || { [ ! "$isExclude" ] && [ "$isMatch" ]; }
	then
	    write "${line}$EOL" "${matchFileIndices["$match"]}" t
	    hasMatch=t
	    break
	fi
    done
    [ "$hasMatch" ] || write "${line}$EOL" "$fallbackFileIndices" t
done
exit $status
