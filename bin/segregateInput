#!/bin/bash
set -o pipefail
shopt -qs extglob

: ${SEGREGATEINPUT_COMMAND_JOINER='|'}
: ${SEGREGATEINPUT_EXEC_END=;}
: ${SEGREGATEINPUT_INPUT_MARKER='{}'}
inputMarker="$SEGREGATEINPUT_INPUT_MARKER"; unset SEGREGATEINPUT_INPUT_MARKER

printShortUsage()
{
    # Note: short followed by long option; if the user knows the short one, she can
    # skim the long one.
    printf 'Usage: %q %s\n' "$(basename "$1")" "(([-t|--to-command DEFAULT-COMMANDLINE | --to-exec SIMPLECOMMAND [...] ${SEGREGATEINPUT_EXEC_END}] --regexp|--match|--no-match PATTERN|--fallback) ...) | -e|--regexp-command|-m|--match-command|-v|--no-match-command PATTERN \"COMMANDLINE\" | -E|--regexp-exec|-M|--match-exec|-V|--no-match-exec SIMPLECOMMAND [...] ${SEGREGATEINPUT_EXEC_END}) ... [(-f|--fallback-command \"FALLBACK-COMMANDLINE\" | -F|--fallback-exec SIMPLECOMMAND [...] ${SEGREGATEINPUT_EXEC_END}) ...] [-?|-h|--help]"
}
printUsage()
{
    # This is the short help when launched with no or incorrect arguments.
    # It is printed to stderr to avoid accidental processing.
    printShortUsage "$1" >&2
    printf >&2 '\nTry %q --help for more information.\n' "$(basename "$1")"
}
printLongUsage()
{
    # This is the long "man page" when launched with the help argument.
    # It is printed to stdout to allow paging with 'more'.
    cat <<HELPDESCRIPTION
Read from standard input and pipe all consecutive (non-)matching lines (i.e. all
lines that [do not] match a particular PATTERN or have an identical match) to
COMMAND(s).
The first consumer wins; i.e. each line is only piped to a single COMMAND. Any
left-over lines are written to standard output / piped to a FALLBACK-COMMAND.
HELPDESCRIPTION
    echo
    printShortUsage "$1"
    echo
    cat <<HELPTEXT
    --to-command|-t DEFAULT-CMD
			    Pipe into${inputMarker:+ or replace any $inputMarker marker inside}
			    DEFAULT-CMD for consecutive lines captured by any
			    following --regexp, --[no-]match PATTERN or
			    --fallback. With this you can pipe / pass
			    consecutive lines [not] matching more than one
			    PATTERN into a single CMD.
    --to-exec|-t DEFAULT-CMD [...] ${SEGREGATEINPUT_EXEC_END}
			    Pipe into${inputMarker:+ or replace any $inputMarker marker inside}
			    DEFAULT-CMD for consecutive lines captured by any
			    following --regexp, --[no-]match PATTERN or
			    --fallback. All following arguments are taken to be
			    arguments to the CMD until an argument consisting of
			    '${SEGREGATEINPUT_EXEC_END}' is encountered. With this you can pipe / pass
			    consecutive lines [not] matching more than one
			    PATTERN into a single CMD.
    --regexp PATTERN	    Consecutive lines that match PATTERN are written to
			    standard output / piped into ${inputMarker:+or replace any $inputMarker
			    marker inside }DEFAULT-CMD.
    --regexp-command|-e PATTERN CMD
			    Execute CMD. Consecutive lines that match PATTERN
			    ${inputMarker:+either }are piped into${inputMarker:+ or replace any $inputMarker marker
			    inside }CMD.
    --regexp-exec|-E PATTERN CMD [...] ${SEGREGATEINPUT_EXEC_END}
			    Execute CMD; all following arguments are taken to be
			    arguments to the CMD until an argument consisting of
			    '${SEGREGATEINPUT_EXEC_END}' is encountered. Consecutive lines that match
			    PATTERN ${inputMarker:+either }are piped into${inputMarker:+ or replace any $inputMarker
			    marker inside }COMMANDLINE.
    --match PATTERN	    Consecutive lines that have identical matches of
			    PATTERN are written to standard output / piped into
			    ${inputMarker:+or replace any $inputMarker marker inside }DEFAULT-CMD.
    --match-command|-m PATTERN CMD
			    Execute CMD. Consecutive lines that have identical
			    matches of PATTERN ${inputMarker:+either }are piped into${inputMarker:+ or replace
			    any $inputMarker marker inside }CMD.
    --match-exec|-M PATTERN CMD [...] ${SEGREGATEINPUT_EXEC_END}
			    Execute CMD; all following arguments are taken to be
			    arguments to the CMD until an argument consisting of
			    '${SEGREGATEINPUT_EXEC_END}' is encountered.
			    Consecutive lines that have identical matches of
			    PATTERN ${inputMarker:+either }are piped into${inputMarker:+ or replace any $inputMarker
			    marker inside }COMMANDLINE.
    --no-match PATTERN	    Consecutive lines that do not match PATTERN are
			    written to standard output / piped into ${inputMarker:+or replace
			    any $inputMarker marker inside }DEFAULT-CMD.
    --no-match-command|-v PATTERN CMD
			    Execute CMD. Consecutive lines that do not match
			    PATTERN ${inputMarker:+either }are piped into${inputMarker:+ or replace any $inputMarker
			    marker inside }CMD.
    --no-match-exec|-V PATTERN CMD [...] ${SEGREGATEINPUT_EXEC_END}
			    Execute CMD; all following arguments are taken to be
			    arguments to the CMD until an argument consisting of
			    '${SEGREGATEINPUT_EXEC_END}' is encountered. Consecutive lines that do not
			    match PATTERN ${inputMarker:+either }are piped into${inputMarker:+ or replace any
			    $inputMarker marker inside }COMMANDLINE.
    --fallback		    Pipe into${inputMarker:+ or replace any $inputMarker marker inside}
			    DEFAULT-CMD for consecutive lines that aren't
			    captured by any PATTERN instead of writing those to
			    standard output.
    --fallback-command|-f FALLBACK-CMD
			    Pipe into${inputMarker:+ or replace any $inputMarker marker inside}
			    FALLBACK-CMD for consecutive lines that aren't
			    captured by any PATTERN instead of writing those to
			    standard output. When given multiple times, the new
			    FALLBACK-CMD is combined with the existing one in a
			    pipeline.
    --fallback-exec|-F FALLBACK-CMD [...] ${SEGREGATEINPUT_EXEC_END}
			    Pipe into${inputMarker:+ or replace any $inputMarker marker inside}
			    FALLBACK-CMD for consecutive lines that aren't
			    captured by any PATTERN instead of writing those to
			    standard output.
			    All following arguments are taken to be arguments to
			    the CMD until an argument consisting of '${SEGREGATEINPUT_EXEC_END}' is
			    encountered. When given multiple times, the new
			    FALLBACK-CMD is combined with the existing one in a
			    pipeline.
    PATTERN is a POSIX-style unanchored extended regular expression.
    You must not pass the same PATTERN to different kinds of matches (i.e.
    --regexp, --match, or --no-match). The same PATTERN for the same kind of
    match combines the new COMMAND with the existing one in a pipeline.

SEE ALSO:
- segregatetee has the same --regexp / --no-match matching (but no identical
  match segregation) but writes to FILE(s) (also multiple) instead of COMMAND
  sinks. With command substitution targets, it sends all collections of
  (non-)matches to COMMAND(s) instead of invoking a COMMAND potentially multiple
  times for each collection of consecutive (non-)matches.
- withOutputToSinkBasedOnMatch includes the source command execution, invokes
  sinks only after it has seen all output, and applies all PATTERN(s) instead of
  first-PATTERN-wins. Like segregatetee, each sink command sees all lines that
  match their PATTERN instead of invoking a COMMAND potentially multiple times
  for each collection of consecutive (non-)matches.
HELPTEXT
}

readonly FALLBACK_INDEX=-1
readonly STDOUT_INDEX=-2
typeset -a matchPatterns=()
typeset -A matchKind=()
typeset -A matchIsExclude=()
typeset -A matchIsIdenticalContext=()
typeset -A matchCommandIndices=()
fallbackCommandIndex=$FALLBACK_INDEX
let lastUsedIndex=$FALLBACK_INDEX
typeset -a commands=()
submitCommand()
{
    local cmd="${1:?}"; shift
    let lastUsedIndex++
    commands[$lastUsedIndex]="$cmd"
}
addCommandFor()
{
    local kind="${1:?}"; shift
    local pattern="${1?}"; shift
    local cmd="${1:?}"; shift

    if [ -n "$pattern" ] \
	&& local existingIndex=${matchCommandIndices["$pattern"]} \
	&& [ -n "$existingIndex" ]
    then
	if [ "${matchKind["$pattern"]}" != "$kind" ]; then
	    printf >&2 "ERROR: Pattern '%s' is specified more than once for different kinds: --%s and --%s\\n" "$pattern" "${matchKind["$pattern"]}" "$kind"
	    exit 2
	fi

	# Combine the new command with the existing one (by default in a pipeline).
	commands[$existingIndex]+=" $SEGREGATEINPUT_COMMAND_JOINER $cmd"
    elif [ -z "$pattern" ] && [ "$kind" = fallback ] \
	&& [ $fallbackCommandIndex -ne $FALLBACK_INDEX ]
    then
	commands[$fallbackCommandIndex]+=" $SEGREGATEINPUT_COMMAND_JOINER $cmd"
    else
	submitCommand "$cmd"
	addIndexFor "$kind" "$pattern" $lastUsedIndex
    fi
}
addIndexFor()
{
    local kind="${1:?}"; shift
    local pattern="${1?}"; shift
    local index="${1:?}"; shift

    if [ -n "$pattern" ]; then
	matchCommandIndices["$pattern"]=$index
	matchPatterns+=("$pattern")
	matchKind["$pattern"]="$kind"
	case "$kind" in
	    regexp)	;;
	    match)	matchIsIdenticalContext["$pattern"]=t;;
	    no-match)	matchIsExclude["$pattern"]=t;;
	    fallback)	echo >&2 'ERROR: Fallback cannot have a pattern.'; exit 3;;
	    *)		printf >&2 'ASSERT: Unhandled kind: %s\n' "$kind"; exit 3;;
	esac
    else
	fallbackCommandIndex=$index
    fi
}

toCommandIndex=
while [ $# -ne 0 ]
do
    case "$1" in
	--help|-h|-\?)	shift; printLongUsage "$0"; exit 0;;

	--regexp=*)	pattern="${1#--regexp=}"; shift
			addIndexFor regexp "${pattern:?}" ${toCommandIndex:-$STDOUT_INDEX}
			;;
	--regexp)	shift; pattern="${1:?}"; shift
			addIndexFor regexp "$pattern" ${toCommandIndex:-$STDOUT_INDEX}
			;;
	--regexp-command|-e)
			shift; pattern="${1:?}"; shift
			addCommandFor regexp "$pattern" "${1:?}"; shift
			;;
	--regexp-exec|-E)
			shift; pattern="${1:?}"; shift
			cmd=
			printf -v escapedInputMarker %q "$inputMarker"
			while [ $# -gt 0 -a "$1" != "$SEGREGATEINPUT_EXEC_END" ]
			do
			    printf -v quotedArg %q "$1"
			    cmd+="${cmd:+ }${quotedArg//"$escapedInputMarker"/$inputMarker}"	# %q escapes {}, we don't want that to have it interpolated later.
			    shift
			done
			if [ $# -eq 0 ]; then
			    echo "ERROR: --regexp-exec command must be concluded with '${SEGREGATEINPUT_EXEC_END}'"; echo; printUsage "$0"
			    exit 2
			fi >&2
			shift
			addCommandFor regexp "$pattern" "$cmd"
			;;
	--match=*)	pattern="${1#--match=}"; shift
			addIndexFor match "${pattern:?}" ${toCommandIndex:-$STDOUT_INDEX}
			;;
	--match)	shift; pattern="${1:?}"; shift
			addIndexFor match "$pattern" ${toCommandIndex:-$STDOUT_INDEX}
			;;
	--match-command|-m)
			shift; pattern="${1:?}"; shift
			addCommandFor match "$pattern" "${1:?}"; shift
			;;
	--match-exec|-M)
			shift; pattern="${1:?}"; shift
			cmd=
			printf -v escapedInputMarker %q "$inputMarker"
			while [ $# -gt 0 -a "$1" != "$SEGREGATEINPUT_EXEC_END" ]
			do
			    printf -v quotedArg %q "$1"
			    cmd+="${cmd:+ }${quotedArg//"$escapedInputMarker"/$inputMarker}"	# %q escapes {}, we don't want that to have it interpolated later.
			    shift
			done
			if [ $# -eq 0 ]; then
			    echo "ERROR: --match-exec command must be concluded with '${SEGREGATEINPUT_EXEC_END}'"; echo; printUsage "$0"
			    exit 2
			fi >&2
			shift
			addCommandFor match "$pattern" "$cmd"
			;;
	--no-match=*)	pattern="${1#--no-match=}"; shift
			addIndexFor no-match "${pattern:?}" ${toCommandIndex:-$STDOUT_INDEX}
			;;
	--no-match)	shift; pattern="${1:?}"; shift
			addIndexFor no-match "$pattern" ${toCommandIndex:-$STDOUT_INDEX}
			;;
	--no-match-command|-v)
			shift; pattern="${1:?}"; shift
			addCommandFor no-match "$pattern" "${1:?}"; shift
			;;
	--no-match-exec|-V)
			shift; pattern="${1:?}"; shift
			cmd=
			printf -v escapedInputMarker %q "$inputMarker"
			while [ $# -gt 0 -a "$1" != "$SEGREGATEINPUT_EXEC_END" ]
			do
			    printf -v quotedArg %q "$1"
			    cmd+="${cmd:+ }${quotedArg//"$escapedInputMarker"/$inputMarker}"	# %q escapes {}, we don't want that to have it interpolated later.
			    shift
			done
			if [ $# -eq 0 ]; then
			    echo "ERROR: --no-match-exec command must be concluded with '${SEGREGATEINPUT_EXEC_END}'"; echo; printUsage "$0"
			    exit 2
			fi >&2
			shift
			addCommandFor no-match "$pattern" "$cmd"
			;;
	--fallback)	shift
			addIndexFor fallback '' ${toCommandIndex:-$STDOUT_INDEX}
			;;
	--fallback-command|-f)
			shift
			addCommandFor fallback '' "${1:?}"; shift
			;;
	--fallback-exec|-F)
			shift
			cmd=
			printf -v escapedInputMarker %q "$inputMarker"
			while [ $# -gt 0 -a "$1" != "$SEGREGATEINPUT_EXEC_END" ]
			do
			    printf -v quotedArg %q "$1"
			    cmd+="${cmd:+ }${quotedArg//"$escapedInputMarker"/$inputMarker}"	# %q escapes {}, we don't want that to have it interpolated later.
			    shift
			done
			if [ $# -eq 0 ]; then
			    echo "ERROR: --fallback-exec command must be concluded with '${SEGREGATEINPUT_EXEC_END}'"; echo; printUsage "$0"
			    exit 2
			fi >&2
			shift
			addCommandFor fallback '' "$cmd"
			;;
	--to-command|-t)
			shift; submitCommand "${1:?}"; shift; toCommandIndex=$lastUsedIndex;;
	--to-exec|-T)	shift
			cmd=
			printf -v escapedInputMarker %q "$inputMarker"
			while [ $# -gt 0 -a "$1" != "$SEGREGATEINPUT_EXEC_END" ]
			do
			    printf -v quotedArg %q "$1"
			    cmd+="${cmd:+ }${quotedArg//"$escapedInputMarker"/$inputMarker}"	# %q escapes {}, we don't want that to have it interpolated later.
			    shift
			done
			if [ $# -eq 0 ]; then
			    echo "ERROR: --to-exec command must be concluded with '${SEGREGATEINPUT_EXEC_END}'"; echo; printUsage "$0"
			    exit 2
			fi >&2
			shift
			submitCommand "$cmd"
			toCommandIndex=$lastUsedIndex
			;;
	-*)		{ echo "ERROR: Unknown option \"$1\"!"; echo; printUsage "$0"; } >&2; exit 2;;
	*)		break;;
    esac
done
if [ $# -ne 0 ]; then
    printUsage "$0"
    exit 2
elif [ ${#matchPatterns[@]} -eq 0 ]; then
    echo 'ERROR: No --regexp, --match, or --no-match passed.'
    echo
    printUsage "$0"
    exit 2
fi >&2

write()
{
    local index="${1:?}"; shift
    [ $index -eq $FALLBACK_INDEX ] && index=$fallbackCommandIndex
    if [ $index -lt 0 ]; then
	printf '%s\n' "$@"
	return
    fi

    local sinkCommand="${commands[$index]}"
    local quotedLines; printf -v quotedLines '%q ' "$@"; quotedLines="${quotedLines% }"
    local interpolatedSinkCommand="${sinkCommand//"$inputMarker"/$quotedLines}"
    if [ "$interpolatedSinkCommand" = "$sinkCommand" ]; then
	printf '%s\n' "$@" | eval "$sinkCommand"
    else
	eval "$interpolatedSinkCommand"
    fi || status=$?
}

status=0
typeset -a consecutiveLines=()
previousIndex=$FALLBACK_INDEX
unset previousContext
while IFS=$'\n' read -r line || [ -n "$line" ]
do
    index=$FALLBACK_INDEX
    unset context
    for match in "${matchPatterns[@]}"
    do
	isExclude="${matchIsExclude["$match"]}"
	isIdenticalContext="${matchIsIdenticalContext["$match"]}"
	isMatch=; [[ "$line" =~ $match ]] && isMatch=t
	if { [ "$isExclude" ] && [ ! "$isMatch" ]; } \
	    || { [ ! "$isExclude" ] && [ "$isMatch" ]; }
	then
	    index="${matchCommandIndices["$match"]}"
	    [ "$isIdenticalContext" ] \
		&& context="${BASH_REMATCH[0]}" \
		|| unset context
	    break
	fi
    done

    if [ $previousIndex -eq $index ] && [ -z "${context+t}" -o -z "${previousContext+t}" -o "$previousContext" = "$context" ]; then
	consecutiveLines+=("$line")
    else
	[ ${#consecutiveLines[@]} -eq 0 ] \
	    || write "$previousIndex" "${consecutiveLines[@]}"
	consecutiveLines=("$line")
	previousIndex=$index
	[ -n "${context+t}" ] \
	    && previousContext="$context" \
	    || unset previousContext
    fi
done
if [ ${#consecutiveLines[@]} -gt 0 ]; then
    write "$previousIndex" "${consecutiveLines[@]}"
    consecutiveLines=()
fi
exit $status
